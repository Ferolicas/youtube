# ============================================================
#  Planeta Keto Intelligence — plantilla de entorno
#  Copia a .env y rellena. NUNCA subas .env al repo.
# ============================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
# Email único autorizado a entrar (tu cuenta de Google)
ALLOWED_EMAIL=sfmtutoriales@gmail.com
# Alcance de la inteligencia: false = SOLO vídeos largos (default; los Shorts solo
# en la pestaña Vídeos). true = incluir Shorts en todo el análisis.
INCLUDE_SHORTS=false

# --- Sesión (HMAC para cookie firmada). Genera: openssl rand -hex 32 ---
SESSION_SECRET=

# --- Cifrado de tokens OAuth en BD (AES-256-GCM, 32 bytes hex = 64 chars).
#     Genera: openssl rand -hex 32 ---
TOKEN_ENC_KEY=

# --- PostgreSQL nativo ---
DATABASE_URL=postgres://youtube_app:password@localhost:5432/youtube_analytics
PGSSLMODE=disable

# --- Google OAuth (Google Cloud Console) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Debe coincidir EXACTO con el "Authorized redirect URI" en Google Cloud
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# YouTube Data API key (para search/trends sin OAuth, opcional pero recomendado)
YOUTUBE_API_KEY=

# --- Binarios externos (rutas o nombres en PATH) ---
YT_DLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg
PYTHON_BIN=python3

# --- Whisper (transcripción fallback) ---
WHISPER_MODEL=large-v3-turbo
WHISPER_COMPUTE_TYPE=int8
WHISPER_THREADS=3
WHISPER_LANG=es

# --- Almacenamiento local ---
DATA_DIR=./data            # audios, csv reporting, etc.
MEDIA_DIR=./media          # miniaturas descargadas

# --- LLM para ideas/guiones (opcional; sin esto hay fallback determinista para ideas,
#     pero los guiones requieren LLM). El proveedor se infiere del modelo:
#     "claude-*" usa ANTHROPIC_API_KEY; el resto usa OPENAI_API_KEY. ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o
# Embeddings para clustering semántico (OpenAI; opcional, con fallback TF-IDF)
EMBEDDINGS_MODEL=text-embedding-3-small

# --- TIEMPO REAL ---
# Pulso del catálogo (snapshot de vistas/likes cada N min; ~1u por 50 vídeos)
CRON_PULSE=*/30 * * * *
# Breakout: alerta si un vídeo gana >= MIN vistas/hora Y >= FACTOR x su ritmo de 7 días
BREAKOUT_MIN_GAIN=150
BREAKOUT_FACTOR=4

# --- Alertas Telegram (opcional; sin esto las alertas solo se guardan en BD) ---
# Crea un bot con @BotFather y saca tu chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WebSub: push instantáneo de subidas (propias y de competidores) ---
# Requiere APP_URL https público. Genera el secret: openssl rand -hex 24
WEBSUB_SECRET=

# --- Radar de competidores y rank tracking ---
# Nº de canales competidores seguidos a diario por playlist (1u/canal)
COMPETITOR_RADAR_SIZE=15
# Día para el descubrimiento por search.list (100u/búsqueda): 0=domingo .. 6=sábado
TRENDS_SEARCH_DOW=1
# Keywords cuya posición se chequea al día (100u cada una; 0 = desactivado)
RANK_KEYWORDS_PER_DAY=5

# --- Cuotas (límites diarios para corte preventivo) ---
QUOTA_DATA_DAILY=10000
QUOTA_ANALYTICS_DAILY=10000
QUOTA_SAFETY_MARGIN=0.92

# --- Cron (zona horaria y horarios) ---
TZ=America/Mexico_City
# Cron único del pipeline diario (sync -> analysis -> trends+ideas). Lo ejecuta pk-daily.
CRON_DAILY=0 7 * * *
# Crons heredados (solo para los workers individuales --once; pk-daily no los usa).
CRON_SYNC=0 6 * * *
CRON_TRENDS=0 7 * * *
CRON_ANALYSIS=30 7 * * *

# --- (Opcional) Ruta absoluta del .env para PM2. La fija ecosystem.config.cjs;
#     no hace falta ponerla aquí. Garantiza que cada proceso cargue ESTE .env. ---
# PK_ENV_FILE=/apps/youtube/.env
